<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Registration Success</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">
  <div class="min-h-screen flex items-center justify-center p-4">
    <div class="bg-white shadow-lg rounded-lg p-8 w-full max-w-md">
      
      <!-- Success Header -->
      <div class="text-center mb-6">
        <div class="inline-block bg-green-100 rounded-full p-3 mb-4">
          <svg class="w-8 h-8 text-green-600" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
        </div>
        <h1 class="text-3xl font-bold text-gray-800 mb-2">Welcome, {{fullName}}!</h1>
        <p class="text-gray-600">Your registration was successful</p>
      </div>

      <!-- Profile Picture -->
      <div class="mb-6 text-center">
        <img 
          src="{{profileImage}}" 
          alt="Profile Picture" 
          class="w-32 h-32 rounded-full object-cover mx-auto border-4 border-blue-500"
        >
      </div>

      <!-- Registration Summary -->
      <div class="bg-gray-50 rounded-lg p-4 mb-6 space-y-3">
        <div class="border-b border-gray-200 pb-3">
          <p class="text-sm text-gray-600 font-semibold">Full Name</p>
          <p class="text-lg text-gray-800">{{fullName}}</p>
        </div>

        <div class="border-b border-gray-200 pb-3">
          <p class="text-sm text-gray-600 font-semibold">Email Address</p>
          <p class="text-lg text-gray-800">{{email}}</p>
        </div>

        <div>
          <p class="text-sm text-gray-600 font-semibold">Course Track</p>
          <p class="text-lg text-gray-800">{{course}}</p>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="flex gap-3">
        <a 
          href="/register" 
          class="flex-1 bg-blue-600 text-white font-semibold py-2 rounded-lg text-center hover:bg-blue-700 transition duration-200"
        >
          Register Another
        </a>
        <button 
          onclick="window.print()" 
          class="flex-1 bg-gray-300 text-gray-800 font-semibold py-2 rounded-lg hover:bg-gray-400 transition duration-200"
        >
          Print
        </button>
      </div>
    </div>
  </div>
</body>
</html>
